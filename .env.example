# AI providers. OpenAI is preferred ("hard brain"); DeepSeek is the fallback.
# Force one with AI_PROVIDER=openai|deepseek. Keep keys server-side only.
OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"
# AI_PROVIDER="openai"
DEEPSEEK_API_KEY=""

# Optional DeepSeek overrides (defaults shown):
# DEEPSEEK_BASE_URL="https://api.deepseek.com"
# DEEPSEEK_MODEL="deepseek-chat"

# APP_URL: The public URL where this server is hosted.
APP_URL="https://assistant.afaq24.store"

# ELEVENLABS_API_KEY: Optional. Used server-side for ElevenLabs voice summaries.
# Bring-Your-Own-Key is also supported directly on the client UI cache.
ELEVENLABS_API_KEY=""
