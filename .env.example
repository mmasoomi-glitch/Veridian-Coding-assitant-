# AI provider — Anthropic-compatible ONLY (no DeepSeek/OpenAI/Gemini/CLI).
# Real values live in a local env file referenced by VERIDIAN_ENV_FILE; leave these empty here.
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
VERIDIAN_ENV_FILE=
VERIDIAN_AUTH=totp
VERIDIAN_PROVISIONING_SECRET=
VERIDIAN_MODE=local-agent

# APP_URL: The public URL where this server is hosted.
APP_URL="https://assistant.afaq24.store"

# ELEVENLABS_API_KEY: Optional. Used server-side for ElevenLabs voice summaries.
# Bring-Your-Own-Key is also supported directly on the client UI cache.
ELEVENLABS_API_KEY=""
